{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Souls Studio",
  "identifier": "com.soulsdirectory.studio",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "pnpm run build",
    "beforeDevCommand": "pnpm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Souls Studio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../library": "library"
    },
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "souls-studio"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/thedaviddias/souls-directory/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNEU1RDlFMDQ3MEM4REUKUldUZXlIQUVubDFPaTR4WmdEN3VyNjBnNWs5TmxjN3YrcUxQbGZyamdWbmwwcEFRMXczd1pscmcK"
    }
  }
}
