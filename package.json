{
  "name": "souls-directory",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "turbo run typecheck",
    "validate": "biome check . --write && pnpm typecheck",
    "test": "turbo run test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "lefthook": "^2.1.5",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.1"
  }
}
